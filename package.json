{
  "name": "dental-clinic-desktop",
  "productName": "Darediya Dental Hub PMS",
  "version": "1.0.0",
  "description": "Offline patient records, appointments, and prescriptions for Darediya Dental Hub",
  "author": "Darediya Dental Hub",
  "private": true,
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "dist": "npm run build && electron-builder",
    "dist:dir": "npm run build && electron-builder --dir",
    "preview": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@fontsource/noto-sans-gujarati": "^5.2.7",
    "archiver": "^8.0.0",
    "better-sqlite3": "^12.11.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.18.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/archiver": "^8.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.0",
    "electron-vite": "^3.1.0",
    "typescript": "^5.7.0",
    "vite": "^6.3.0"
  },
  "build": {
    "appId": "com.darediya.dentalhubpms",
    "productName": "Darediya Dental Hub PMS",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "resources/**/*"
    ],
    "extraResources": [],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Darediya Dental Hub PMS"
    },
    "asarUnpack": [
      "**/*.node"
    ]
  }
}
